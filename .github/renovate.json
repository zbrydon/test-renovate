{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "configMigration": true,
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Route public.ecr.aws / registry.k8s.io / quay.io / docker.io images through the ECR pull-through cache",
      "matchManagers": ["dockerfile"],
      "matchDatasources": ["docker"],
      "matchFileNames": ["**/Dockerfile*"],
      "matchPackageNames": [
        "public.ecr.aws/**",
        "registry.k8s.io/**",
        "quay.io/**",
        "docker.io/**"
      ],
      "replacementNameTemplate": "111111111111.dkr.ecr.ap-southeast-2.amazonaws.com/{{{packageName}}}"
    },
    {
      "description": "Route Docker Hub official (library) images through the ECR pull-through cache",
      "matchManagers": ["dockerfile"],
      "matchDatasources": ["docker"],
      "matchFileNames": ["**/Dockerfile*"],
      "matchPackageNames": ["/^[a-z0-9][a-z0-9-]*$/"],
      "replacementNameTemplate": "111111111111.dkr.ecr.ap-southeast-2.amazonaws.com/docker.io/library/{{{packageName}}}"
    },
    {
      "description": "Route namespaced Docker Hub images through the ECR pull-through cache",
      "matchManagers": ["dockerfile"],
      "matchDatasources": ["docker"],
      "matchFileNames": ["**/Dockerfile*"],
      "matchPackageNames": ["/^[a-z0-9][a-z0-9-]*\\/[a-z0-9._/-]+$/"],
      "replacementNameTemplate": "111111111111.dkr.ecr.ap-southeast-2.amazonaws.com/docker.io/{{{packageName}}}"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)serverless(\\..*)?\\.ya?ml$/"],
      "matchStrings": [
        "frameworkVersion:\\s*['\"](?<currentValue>[^'\"]+)['\"]"
      ],
      "depNameTemplate": "serverless",
      "datasourceTemplate": "npm"
    }
  ],
  "postUpdateOptions": ["yarnDedupeFewer", "pnpmDedupe"],
  "prCreation": "immediate",
  "prHourlyLimit": 10,
  "semanticCommitScope": "",
  "semanticCommitType": "deps"
}
