{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "configMigration": true,
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Route public.ecr.aws / registry.k8s.io / quay.io images through the ECR pull-through cache (docker.io is handled by the next rule so library/ can be injected)",
      "matchDatasources": ["docker"],
      "matchFileNames": ["**/Dockerfile*"],
      "matchPackageNames": [
        "public.ecr.aws/**",
        "registry.k8s.io/**",
        "quay.io/**",
        "!111111111111.dkr.ecr.ap-southeast-2.amazonaws.com/**"
      ],
      "replacementNameTemplate": "111111111111.dkr.ecr.ap-southeast-2.amazonaws.com/{{{packageName}}}"
    },
    {
      "description": "Route Docker Hub images (bare names and explicit docker.io/ names) through the ECR pull-through cache, injecting library/ for official images",
      "matchDatasources": ["docker"],
      "matchFileNames": ["**/Dockerfile*"],
      "matchPackageNames": [
        "/^(?:docker\\.io\\/)?[^./]+(?:\\/.+)?$/",
        "!111111111111.dkr.ecr.ap-southeast-2.amazonaws.com/**"
      ],
      "replacementNameTemplate": "111111111111.dkr.ecr.ap-southeast-2.amazonaws.com/docker.io/{{ replace '^([^/]+)$' 'library/$1' (replace '^docker\\.io/' '' packageName) }}"
    },
    {
      "description": "Consolidate all ECR pull-through cache replacements into a single PR",
      "matchFileNames": ["**/Dockerfile*"],
      "matchUpdateTypes": ["replacement"],
      "groupName": "ECR pull-through cache migration",
      "branchTopic": "docker-ecr-pull-through-cache",
      "commitMessageAction": "",
      "commitMessageExtra": "",
      "prBodyTemplate": "{{{header}}}{{{table}}}{{{warnings}}}{{{changelogs}}}{{{configDescription}}}{{{controls}}}{{{footer}}}",
      "prFooter": "---\n\n📖 See the [ECR pull-through cache runbook](https://example.com/docs/ecr-pull-through-cache) for context on these replacements."
    },
    {
      "description": "Do not apply ECR pull-through cache replacements to FROM lines already routed via the ${ECR_REGISTRY_PREFIX} build arg; this prevents duplicating the registry prefix. Version (tag) updates are unaffected.",
      "matchDatasources": ["docker"],
      "matchFileNames": ["**/Dockerfile*"],
      "matchUpdateTypes": ["replacement"],
      "matchJsonata": ["$contains(replaceString, '${ECR_REGISTRY_PREFIX}')"],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)serverless(\\..*)?\\.ya?ml$/"],
      "matchStrings": [
        "frameworkVersion:\\s*['\"](?<currentValue>[^'\"]+)['\"]"
      ],
      "depNameTemplate": "serverless",
      "datasourceTemplate": "npm"
    }
  ],
  "postUpdateOptions": ["yarnDedupeFewer", "pnpmDedupe"],
  "prCreation": "immediate",
  "prHourlyLimit": 10,
  "semanticCommitScope": "",
  "semanticCommitType": "deps"
}
